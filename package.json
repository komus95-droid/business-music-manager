{
  "name": "business-music-manager",
  "version": "1.0.0",
  "description": "Commercial Player by RunBizAi — управление фоновой музыкой и объявлениями",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --target=node18 --external:electron --format=cjs --outfile=dist-electron/preload/preload.js",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "npm run build:main && node test/smoke.cjs",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.runbizai.commercialplayer",
    "productName": "Commercial Player",
    "artifactName": "Commercial-Player-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "1049",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "shortcutName": "Commercial Player"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/howler": "^2.2.13",
    "howler": "^2.2.4",
    "music-metadata": "^11.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
